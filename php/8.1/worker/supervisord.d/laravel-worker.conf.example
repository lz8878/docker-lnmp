[program:laravel-worker]
process_name=%(program_name)s_%(process_num)02d
command=php /wwwdata/www/example.com/artisan queue:work --sleep=3 --tries=3 --max-time=3600
autostart=true
autorestart=true
stopasgroup=true
killasgroup=true
user=www-data
numprocs=8
redirect_stderr=true
stdout_logfile=/wwwdata/www/example.com/storage/logs/worker.log
stopwaitsecs=3600
